# Google Gemini Configuration
# Option 1: Using Service Account (Vertex AI - Recommended)
GOOGLE_APPLICATION_CREDENTIALS=etc/secrets/gcp-key.json
GCP_LOCATION=us-central1
GCP_PROJECT_ID=your_project_id

# Option 2: Using API Key (AI Studio)
GOOGLE_API_KEY=your_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# Proxies for Web Scraping
# Provide a comma-separated list of proxies (e.g., http://proxy1:port,http://user:pass@proxy2:port)
PROXIES=
